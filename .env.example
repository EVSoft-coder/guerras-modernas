APP_NAME="Guerras Modernas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=pt
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_PT

PHP_CLI_SERVER_WORKERS=4

# --- DATABASE CONFIG ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=guerras_modernas
DB_USERNAME=root
DB_PASSWORD=

# --- SESSION & CACHE ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- GAME BALANCE (SPEED MODIFIERS) ---
# Multiplicadores para acelerar o jogo (estilo Speed Server)
GAME_SPEED_RESOURCES=10
GAME_SPEED_CONSTRUCTION=10
GAME_SPEED_TRAINING=10
GAME_SPEED_TRAVEL=5

# --- MAIL CONFIG ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@guerrasmodernas.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- FRONTEND ASSETS ---
VITE_APP_NAME="${APP_NAME}"
